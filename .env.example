# Atrium executor config. Copy to backend/.env (or export) before `npm --prefix backend run dev`.

# --- the ledger ---
LEDGER_API_URL=http://localhost:7575   # local sandbox; for Seaport use your validator's JSON Ledger API v2 URL
LEDGER_USER_ID=participant_admin       # sandbox user; on Seaport, the validator/app user id
PORT=8080

# --- auth (pick ONE; leave all blank for the local no-auth sandbox) ---
# 1) paste a static Bearer JWT (quickest way to test a hosted validator)
# LEDGER_TOKEN=

# 2) OIDC client-credentials — the Seaport / hosted-validator path (Loop DevNet wallet issuer).
#    Set OIDC_TOKEN_URL directly, or OIDC_ISSUER to discover it via .well-known/openid-configuration.
# OIDC_ISSUER=
# OIDC_TOKEN_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_AUDIENCE=
# OIDC_SCOPE=

# --- hosted (Seaport) extras ---
# LEDGER_USER_ID=6              # the ledger user the token authenticates as
# LEDGER_GRANT_ACT_AS=1         # grant that user CanActAs on parties we submit as (hosted only)
# PARTY_PREFIX=atrium-          # namespace our party hints on a SHARED validator
# PARTY_NAMESPACE=<fingerprint> # the validator's shared namespace; lets us build party ids w/o listing 10k
# ATRIUM_PKG=<dar package id>   # so we can seed before any Atrium contract exists
# Deploy the DAR + seed once:  curl -X POST $BASE/v2/packages (or Seaport IDE);  POST /deals/HALDEN-2026-A/seed

# --- diligence copilot (Venice AI — privacy-preserving, OpenAI-compatible) ---
# VENICE_API_KEY=          # required to enable the /ask copilot
# VENICE_MODEL=llama-3.3-70b
# VENICE_BASE_URL=https://api.venice.ai/api/v1

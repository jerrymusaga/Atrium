# Atrium executor config. Copy to backend/.env (or export) before `npm --prefix backend run dev`.

# --- the ledger ---
LEDGER_API_URL=http://localhost:7575   # local sandbox; for Seaport use your validator's JSON Ledger API v2 URL
LEDGER_USER_ID=participant_admin       # sandbox user; on Seaport, the validator/app user id
PORT=8080

# --- auth (pick ONE; leave all blank for the local no-auth sandbox) ---
# 1) paste a static Bearer JWT (quickest way to test a hosted validator)
# LEDGER_TOKEN=

# 2) OIDC client-credentials — the Seaport / hosted-validator path (Loop DevNet wallet issuer).
#    Set OIDC_TOKEN_URL directly, or OIDC_ISSUER to discover it via .well-known/openid-configuration.
# OIDC_ISSUER=
# OIDC_TOKEN_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_AUDIENCE=
# OIDC_SCOPE=
